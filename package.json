{
  "name": "webapp",
  "type": "module",
  "scripts": {
    "dev": "npm run build:css && vite",
    "build:css": "tailwindcss -i ./src/styles/main.css -o ./public/static/style.css --minify",
    "watch:css": "tailwindcss -i ./src/styles/main.css -o ./public/static/style.css --watch",
    "build": "npm run build:css && vite build",
    "preview": "wrangler pages dev",
    "deploy": "npm run build && wrangler pages deploy",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings",
    "lint": "echo 'lint placeholder'",
    "test": "echo 'no tests yet'"
  },
  "dependencies": {
    "hono": "^4.12.12"
  },
  "devDependencies": {
    "@hono/vite-build": "^1.2.0",
    "@hono/vite-dev-server": "^0.18.2",
    "autoprefixer": "^10.5.0",
    "postcss": "^8.5.12",
    "tailwindcss": "^3.4.19",
    "vite": "^6.3.5",
    "wrangler": "^4.4.0"
  }
}
